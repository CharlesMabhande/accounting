<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- All NuGet packages are restored under .\packages so the folder can be zipped for offline builds. -->
  <config>
    <add key="globalPackagesFolder" value="packages" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
