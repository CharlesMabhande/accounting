<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- CharlzTech brand palette (from logo: navy wordmark, electric blue cloud, cyan pixels) — primary UI blue: #0066FF family -->
  <FontFamily x:Key="Font.Icon">Segoe MDL2 Assets</FontFamily>

  <Color x:Key="Color.BrandNavy">#001B44</Color>
  <Color x:Key="Color.BrandNavyLight">#003A7A</Color>
  <Color x:Key="Color.Accent">#0066FF</Color>
  <Color x:Key="Color.AccentHover">#3385FF</Color>
  <Color x:Key="Color.Cyan">#00D2FF</Color>
  <Color x:Key="Color.SurfacePage">#EEF4FC</Color>
  <Color x:Key="Color.SurfacePanel">#FFFFFF</Color>
  <Color x:Key="Color.SurfaceMuted">#F0F4F8</Color>
  <Color x:Key="Color.BorderSubtle">#D4DDE8</Color>
  <Color x:Key="Color.TextPrimary">#001B44</Color>
  <Color x:Key="Color.TextSecondary">#4A5F7A</Color>
  <Color x:Key="Color.TextMuted">#6B7C93</Color>

  <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
  <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="Brush.TextOnDark" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
  <SolidColorBrush x:Key="Brush.AccentSoft" Color="#E6F0FF" />
  <SolidColorBrush x:Key="Brush.AccentSurface" Color="#D6E8FF" />
  <SolidColorBrush x:Key="Brush.Cyan" Color="{StaticResource Color.Cyan}" />
  <SolidColorBrush x:Key="Brush.CyanSoft" Color="#E6FBFF" />
  <SolidColorBrush x:Key="Brush.SurfacePage" Color="{StaticResource Color.SurfacePage}" />
  <SolidColorBrush x:Key="Brush.SurfacePanel" Color="{StaticResource Color.SurfacePanel}" />
  <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{StaticResource Color.SurfaceMuted}" />
  <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}" />
  <SolidColorBrush x:Key="Brush.SectionHeader" Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="Brush.ReportAccent" Color="#0052CC" />

  <LinearGradientBrush x:Key="Brush.BrandBarGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#001B44" Offset="0" />
    <GradientStop Color="#003A7A" Offset="0.55" />
    <GradientStop Color="#0066FF" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="Brush.PanelHeaderGradient" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="#F8FAFD" Offset="0" />
    <GradientStop Color="#EEF4FF" Offset="1" />
  </LinearGradientBrush>

  <!-- Default button: light surface + accent on hover -->
  <Style TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="Background" Value="{DynamicResource Brush.SurfacePanel}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentSurface}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.55" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="BrandToolbarButton" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextOnDark}" />
    <Setter Property="Background" Value="#33FFFFFF" />
    <Setter Property="BorderBrush" Value="#55FFFFFF" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#77FFFFFF" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="AccentPrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextOnDark}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentHover}" />
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.AccentHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="#0052CC" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CaretBrush" Value="{DynamicResource Brush.Accent}" />
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
    <Setter Property="Padding" Value="6,4" />
  </Style>

  <Style x:Key="TextBlock.IconAccent" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource Font.Icon}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style x:Key="TextBlock.IconOnDark" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource Font.Icon}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextOnDark}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CaretBrush" Value="{DynamicResource Brush.Accent}" />
  </Style>

</ResourceDictionary>
