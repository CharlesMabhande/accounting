<Window x:Class="Accounting.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:Accounting.Desktop.Shell"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="CharlzTech Accounting"
        Height="760"
        Width="1180"
        MinHeight="600"
        MinWidth="960"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        Background="{DynamicResource Brush.SurfacePage}"
        Loaded="MainWindow_OnLoaded"
        Closing="MainWindow_OnClosing">
  <Window.Resources>
    <HierarchicalDataTemplate DataType="{x:Type shell:ShellNavNode}" ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Margin="0,0,6,0"
                   VerticalAlignment="Center"
                   FontFamily="{DynamicResource Font.Icon}"
                   FontSize="14"
                   Foreground="{DynamicResource Brush.Accent}"
                   Text="{Binding IconGlyph}" />
        <TextBlock Text="{Binding Title}"
                   FontWeight="SemiBold"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextPrimary}" />
        <TextBlock Margin="6,0,0,0"
                   VerticalAlignment="Bottom"
                   FontSize="11"
                   Foreground="{DynamicResource Brush.TextMuted}"
                   Text="{Binding Caption}" />
      </StackPanel>
    </HierarchicalDataTemplate>
  </Window.Resources>

  <DockPanel LastChildFill="True">
    <!-- Menu -->
    <Menu DockPanel.Dock="Top"
          Background="{DynamicResource Brush.SurfaceMuted}"
          Padding="0,3">
      <MenuItem Header="_File">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE8B7;" />
        </MenuItem.Icon>
        <MenuItem Header="_Exit" Click="MenuExit_Click">
          <MenuItem.Icon>
            <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="14" Text="&#xE711;" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Dashboard" Click="MenuHome_Click">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE80F;" />
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE890;" />
        </MenuItem.Icon>
        <MenuItem Header="_Home dashboard" Click="MenuHome_Click" />
        <Separator />
        <MenuItem Header="_Refresh company list" Click="MenuRefreshCompanies_Click" />
      </MenuItem>
      <MenuItem Header="_Maintenance">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE713;" />
        </MenuItem.Icon>
        <MenuItem Header="_Companies" Click="MenuOpenModule_Click" Tag="companies" />
        <MenuItem Header="_Customers" Click="MenuOpenModule_Click" Tag="ar_customers" />
        <MenuItem Header="_Suppliers" Click="MenuOpenModule_Click" Tag="ap_suppliers" />
        <MenuItem Header="_Stock items" Click="MenuOpenModule_Click" Tag="inv_items" />
        <MenuItem Header="_Bank accounts" Click="MenuOpenModule_Click" Tag="cb_banks" />
      </MenuItem>
      <MenuItem Header="_Transactions">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE8D5;" />
        </MenuItem.Icon>
        <MenuItem Header="_General ledger workspace" Click="MenuOpenModule_Click" Tag="ledger" />
        <MenuItem Header="_Customer invoices" Click="MenuOpenModule_Click" Tag="ar_invoices" />
        <MenuItem Header="_Supplier invoices" Click="MenuOpenModule_Click" Tag="ap_invoices" />
        <MenuItem Header="_Cashbook" Click="MenuOpenModule_Click" Tag="cb_cashbook" />
      </MenuItem>
      <MenuItem Header="_Reports">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE9F9;" />
        </MenuItem.Icon>
        <MenuItem Header="_Customer statements" Click="MenuOpenModule_Click" Tag="ar_statements" />
        <MenuItem Header="_Trial balance" Click="MenuOpenModule_Click" Tag="gl_trial" />
        <Separator />
        <MenuItem Header="_Open API / Swagger" Click="MenuOpenSwagger_Click" />
      </MenuItem>
      <MenuItem Header="_Enquiries">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE721;" />
        </MenuItem.Icon>
        <MenuItem Header="_Sales orders" Click="MenuOpenModule_Click" Tag="ar_orders" />
        <MenuItem Header="_Purchase orders" Click="MenuOpenModule_Click" Tag="ap_orders" />
        <MenuItem Header="_Warehouse stock" Click="MenuOpenModule_Click" Tag="inv_balance" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem.Icon>
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="15" Text="&#xE897;" />
        </MenuItem.Icon>
        <MenuItem Header="_About" Click="MenuAbout_Click" />
      </MenuItem>
    </Menu>

    <!-- Brand strip + logo -->
    <Border DockPanel.Dock="Top"
            Padding="14,10,16,10"
            BorderThickness="0,0,0,1"
            BorderBrush="#22001B44">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#001B44" Offset="0" />
          <GradientStop Color="#003A7A" Offset="0.5" />
          <GradientStop Color="#0066FF" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center">
        <ct:BrandedLogo VerticalAlignment="Center"
                        LogoHeight="44"
                        CornerRadius="12" />
        <StackPanel Margin="14,2,0,0"
                    VerticalAlignment="Center">
          <TextBlock FontSize="17"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.TextOnDark}"
                     Text="CharlzTech Accounting" />
          <TextBlock Margin="0,2,0,0"
                     FontSize="12"
                     Opacity="0.92"
                     Foreground="{DynamicResource Brush.TextOnDark}"
                     Text="Enterprise accounting workspace" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Toolbar -->
    <ToolBar DockPanel.Dock="Top"
             Padding="8,6"
             Background="{DynamicResource Brush.SurfacePanel}"
             BorderBrush="{DynamicResource Brush.BorderSubtle}"
             BorderThickness="0,0,0,1">
      <Button Click="BackTab_Click"
              ToolTip="Select previous tab">
        <StackPanel Orientation="Horizontal">
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="14" Text="&#xE0A6;" />
          <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Back" />
        </StackPanel>
      </Button>
      <Separator />
      <Button Click="MenuHome_Click"
              FontWeight="SemiBold">
        <StackPanel Orientation="Horizontal">
          <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="14" Text="&#xE80F;" />
          <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Home" />
        </StackPanel>
      </Button>
      <Separator />
      <StackPanel VerticalAlignment="Center"
                  Margin="8,0,6,0"
                  Orientation="Horizontal">
        <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="14" Text="&#xE774;" />
        <TextBlock Margin="6,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   Text="Company" />
      </StackPanel>
      <ComboBox x:Name="CompanyCombo"
                Width="260"
                MinWidth="180"
                SelectedValuePath="Id"
                SelectionChanged="CompanyCombo_OnSelectionChanged">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <TextBlock FontWeight="SemiBold" Text="{Binding Code}" />
              <TextBlock Margin="6,0,0,0" Text="—" />
              <TextBlock Margin="6,0,0,0" Text="{Binding Name}" />
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Separator />
      <StackPanel VerticalAlignment="Center"
                  Margin="8,0,4,0"
                  Orientation="Horizontal">
        <TextBlock Style="{DynamicResource TextBlock.IconAccent}" FontSize="13" Text="&#xE839;" />
        <TextBlock Margin="6,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextMuted}"
                   FontSize="12"
                   Text="API" />
      </StackPanel>
      <TextBlock x:Name="ToolbarApiHint"
                 VerticalAlignment="Center"
                 FontSize="12"
                 Foreground="{DynamicResource Brush.TextPrimary}"
                 Text="…" />
    </ToolBar>

    <!-- Status bar -->
    <StatusBar DockPanel.Dock="Bottom"
               Background="{DynamicResource Brush.SurfaceMuted}"
               Foreground="{DynamicResource Brush.TextSecondary}"
               FontSize="11"
               BorderBrush="{DynamicResource Brush.BorderSubtle}"
               BorderThickness="0,1,0,0">
      <StatusBarItem>
        <TextBlock x:Name="StatusServer" Text="Server: …" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <TextBlock x:Name="StatusDatabase" Text="Database: …" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <TextBlock x:Name="StatusCompany" Text="Company: —" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <TextBlock x:Name="StatusUser" Text="User: Operator" />
      </StatusBarItem>
      <StatusBarItem HorizontalAlignment="Right">
        <TextBlock x:Name="StatusClock" Foreground="{DynamicResource Brush.TextPrimary}" />
      </StatusBarItem>
    </StatusBar>

    <!-- Navigation + tabs -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{DynamicResource Brush.SurfacePanel}"
              BorderBrush="{DynamicResource Brush.BorderSubtle}"
              BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="True">
          <Border DockPanel.Dock="Top"
                  Padding="12,12,12,10"
                  BorderBrush="{DynamicResource Brush.BorderSubtle}"
                  BorderThickness="0,0,0,1">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#F8FAFD" Offset="0" />
                <GradientStop Color="#EEF4FF" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontFamily="{DynamicResource Font.Icon}"
                           FontSize="16"
                           Foreground="{DynamicResource Brush.Accent}"
                           Text="&#xE8F1;" />
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}"
                           Text="Modules" />
              </StackPanel>
              <TextBox x:Name="NavFilterBox"
                       Margin="0,8,0,0"
                       Padding="8,6"
                       ToolTip="Filter modules in the tree"
                       TextChanged="NavFilterBox_TextChanged" />
            </StackPanel>
          </Border>
          <TreeView x:Name="NavTree"
                    BorderThickness="0"
                    Padding="8,8"
                    Background="{DynamicResource Brush.SurfacePanel}"
                    Foreground="{DynamicResource Brush.TextPrimary}"
                    SelectedItemChanged="NavTree_OnSelectedItemChanged">
            <TreeView.Resources>
              <Style BasedOn="{StaticResource {x:Type TreeViewItem}}" TargetType="TreeViewItem">
                <Setter Property="Padding" Value="3" />
                <Style.Triggers>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSurface}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </TreeView.Resources>
          </TreeView>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" Background="{DynamicResource Brush.SurfacePage}">
        <TabControl x:Name="WorkspaceTabs"
                    Margin="0"
                    BorderThickness="0"
                    Background="{DynamicResource Brush.SurfacePanel}">
          <TabControl.Resources>
            <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="TabItem">
              <Setter Property="Margin" Value="0,0,3,0" />
              <Setter Property="Padding" Value="16,10" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
              <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
              <Setter Property="FontSize" Value="13" />
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="{DynamicResource Brush.SurfacePanel}" />
                  <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                  <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TabControl.Resources>
        </TabControl>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
