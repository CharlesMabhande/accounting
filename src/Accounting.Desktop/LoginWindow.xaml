<Window x:Class="Accounting.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="Sign in — CharlzTech Accounting"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.SurfacePage}"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png">
  <Border Padding="28,24">
    <StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <ct:BrandedLogo LogoHeight="56" CornerRadius="14" />
        <StackPanel Margin="14,6,0,0" VerticalAlignment="Center">
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}"
                     Text="CharlzTech Accounting" />
          <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="Sign in with your operator account" />
        </StackPanel>
      </StackPanel>
      <TextBlock Margin="0,24,0,4" Foreground="{DynamicResource Brush.TextSecondary}" Text="User name" />
      <TextBox x:Name="UserBox" Padding="8,6" />
      <TextBlock Margin="0,12,0,4" Foreground="{DynamicResource Brush.TextSecondary}" Text="Password" />
      <PasswordBox x:Name="PasswordBox" Padding="8,6" />
      <TextBlock x:Name="ErrorText" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#C62828" Visibility="Collapsed" />
      <Button Margin="0,20,0,0"
              HorizontalAlignment="Stretch"
              Padding="12,10"
              IsDefault="True"
              Style="{DynamicResource AccentPrimaryButton}"
              Click="SignIn_Click">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock FontFamily="{DynamicResource Font.Icon}"
                     FontSize="15"
                     Foreground="{DynamicResource Brush.TextOnDark}"
                     Text="&#xE8B7;"
                     VerticalAlignment="Center" />
          <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Sign in" />
        </StackPanel>
      </Button>
      <Button Margin="0,8,0,0"
              HorizontalAlignment="Stretch"
              Padding="10,8"
              IsCancel="True"
              Click="Exit_Click">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock FontFamily="{DynamicResource Font.Icon}"
                     FontSize="14"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="&#xE711;"
                     VerticalAlignment="Center" />
          <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Exit" />
        </StackPanel>
      </Button>
    </StackPanel>
  </Border>
</Window>
