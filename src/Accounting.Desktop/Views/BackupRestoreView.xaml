<UserControl x:Class="Accounting.Desktop.Views.BackupRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Backup &amp; restore" />
      <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"
                 Text="Logical backup exports all tables to a ZIP (JSON). Import replaces current data—use only with a matching database provider (SQLite or SQL Server). Native backup downloads the raw SQLite file or a SQL Server .bak." />
      <TextBlock x:Name="BackupPathHint"
                 Margin="0,8,0,0"
                 Foreground="{DynamicResource Brush.TextSecondary}"
                 TextWrapping="Wrap"
                 FontSize="11" />
    </StackPanel>
    <StackPanel Grid.Row="1" Margin="0,16,0,8">
      <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Logical (portable)" />
      <StackPanel Orientation="Horizontal">
        <Button Padding="14,8" Content="Export ZIP…" Click="ExportJson_Click" />
        <Button Margin="8,0,0,0" Padding="14,8" Content="Import ZIP…" Click="ImportJson_Click" />
      </StackPanel>
      <TextBlock Margin="0,16,0,8" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Native file" />
      <StackPanel Orientation="Horizontal">
        <Button HorizontalAlignment="Left" Padding="14,8" Content="Download native backup…" Click="NativeBackup_Click" />
        <Button Margin="10,0,0,0" Padding="14,8" Content="Save log as text…" Click="SaveLog_Click" />
      </StackPanel>
      <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" />
    </StackPanel>
    <TextBox x:Name="LogBox"
             Grid.Row="2"
             Margin="0,8,0,0"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             TextWrapping="Wrap"
             FontFamily="Consolas"
             FontSize="12"
             Background="{DynamicResource Brush.SurfaceMuted}" />
  </Grid>
</UserControl>
