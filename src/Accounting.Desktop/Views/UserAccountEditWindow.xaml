<Window x:Class="Accounting.Desktop.Views.UserAccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="User account"
        Width="440"
        Height="520"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.SurfacePage}">
  <DockPanel LastChildFill="True">
    <ct:BrandedFormHeader DockPanel.Dock="Top"
                          Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                          Subtitle="Operator or agent account"
                          IconGlyph="&#xE77B;" />
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
    <StackPanel>
      <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="User name" />
      <TextBox x:Name="UserNameBox" Margin="0,4,0,12" Padding="6" />
      <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="Display name" />
      <TextBox x:Name="DisplayNameBox" Margin="0,4,0,12" Padding="6" />
      <TextBlock Foreground="{DynamicResource Brush.TextSecondary}"
                 TextWrapping="Wrap"
                 Text="Password — enter the password you want this user or agent to use. Required when creating an account. When editing, leave blank to keep the current password, or type a new password to change or reset it." />
      <PasswordBox x:Name="PasswordBox" Margin="0,4,0,12" Padding="6" />
      <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="Account kind" />
      <ComboBox x:Name="KindCombo" Margin="0,4,0,12">
        <ComboBoxItem Content="Staff" Tag="Staff" />
        <ComboBoxItem Content="Agent" Tag="Agent" />
      </ComboBox>
      <CheckBox x:Name="ActiveCheck" Content="Active" IsChecked="True" Margin="0,0,0,12" />
      <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="Roles (Ctrl+click for multiple)" />
      <ListBox x:Name="RolesList" MinHeight="140" MaxHeight="200" SelectionMode="Multiple" DisplayMemberPath="Name" />
      <StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Padding="12,6" Content="Cancel" IsCancel="True" Click="Cancel_Click" />
        <Button Margin="8,0,0,0" Padding="12,6" Content="Save" IsDefault="True" Click="Save_Click" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
  </DockPanel>
</Window>
