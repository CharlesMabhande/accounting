<Window x:Class="Accounting.Desktop.Views.CustomerStatementPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="Customer statement"
        Width="780"
        Height="640"
        MinWidth="560"
        MinHeight="400"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.SurfacePage}">
  <DockPanel LastChildFill="True">
    <ct:BrandedFormHeader DockPanel.Dock="Top"
                          Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                          Subtitle="Print preview"
                          IconGlyph="&#xE8A5;" />
  <DockPanel>
    <StackPanel DockPanel.Dock="Bottom"
                Margin="12"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button MinWidth="120"
              Padding="12,8"
              Click="SavePdf_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center"
                     FontFamily="{DynamicResource Font.Icon}"
                     FontSize="14"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="&#xE8A5;" />
          <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Save as PDF…" />
        </StackPanel>
      </Button>
      <Button MinWidth="100"
              Margin="10,0,0,0"
              Padding="12,8"
              Style="{DynamicResource AccentPrimaryButton}"
              Click="Print_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center"
                     FontFamily="{DynamicResource Font.Icon}"
                     FontSize="14"
                     Foreground="{DynamicResource Brush.TextOnDark}"
                     Text="&#xE749;" />
          <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Print…" />
        </StackPanel>
      </Button>
      <Button MinWidth="100"
              Margin="10,0,0,0"
              Padding="12,8"
              IsCancel="True"
              Click="Close_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center"
                     FontFamily="{DynamicResource Font.Icon}"
                     FontSize="14"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="&#xE711;" />
          <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Close" />
        </StackPanel>
      </Button>
    </StackPanel>
    <FlowDocumentScrollViewer x:Name="Viewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="8" />
  </DockPanel>
  </DockPanel>
</Window>
