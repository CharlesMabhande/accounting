<UserControl x:Class="Accounting.Desktop.Views.CompaniesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Companies" />
      <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextSecondary}" Text="Organizations from GET api/Companies" />
      <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
        <Button HorizontalAlignment="Left" Padding="12,6" Content="Refresh" Click="Refresh_Click" />
        <Button Margin="8,0,0,0" Padding="12,6" Content="Export CSV…" Click="ExportCsv_Click" />
        <Button Margin="8,0,0,0" Padding="12,6" Content="Export PDF…" Click="ExportPdf_Click" />
      </StackPanel>
    </StackPanel>
    <DataGrid x:Name="Grid" Grid.Row="1"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              RowHeaderWidth="0"
              AlternatingRowBackground="{DynamicResource Brush.SurfaceMuted}"
              CanUserAddRows="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="*" />
        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
        <DataGridTextColumn Header="Currency" Binding="{Binding BaseCurrency}" Width="80" />
        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
