<UserControl x:Class="Accounting.Desktop.Views.FiscalPeriodsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Fiscal periods" />
      <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"
                 Text="Close a period to block posting; reopen when corrections are allowed. Select a row, then Close or Reopen." />
    </StackPanel>
    <StackPanel Grid.Row="1" Margin="0,12,0,8" Orientation="Horizontal">
      <Button Padding="12,6" Content="Refresh" Click="Refresh_Click" />
      <Button Margin="8,0,0,0" Padding="12,6" Content="Close period" Click="ClosePeriod_Click" />
      <Button Margin="8,0,0,0" Padding="12,6" Content="Reopen period" Click="ReopenPeriod_Click" />
      <Button Margin="8,0,0,0" Padding="12,6" Content="Export CSV…" Click="ExportCsv_Click" />
      <Button Margin="8,0,0,0" Padding="12,6" Content="Export PDF…" Click="ExportPdf_Click" />
      <TextBlock x:Name="StatusText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" />
    </StackPanel>
    <DataGrid x:Name="Grid"
              Grid.Row="2"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              RowHeaderWidth="0"
              AlternatingRowBackground="{DynamicResource Brush.SurfaceMuted}"
              CanUserAddRows="False"
              SelectionMode="Single" />
  </Grid>
</UserControl>
