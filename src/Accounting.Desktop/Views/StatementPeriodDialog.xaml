<Window x:Class="Accounting.Desktop.Views.StatementPeriodDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="Customer statement — period"
        Width="380"
        Height="Auto"
        SizeToContent="Height"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.SurfacePage}">
  <DockPanel LastChildFill="True">
    <ct:BrandedFormHeader DockPanel.Dock="Top"
                          Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                          Subtitle="Statement date range"
                          IconGlyph="&#xE787;" />
    <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0"
               Margin="0,0,0,6"
               Foreground="{DynamicResource Brush.TextSecondary}"
               TextWrapping="Wrap"
               Text="Choose the date range for posted invoices and customer receipts." />
    <TextBlock Grid.Row="1" Margin="0,8,0,4" Foreground="{DynamicResource Brush.TextPrimary}" Text="From" />
    <DatePicker x:Name="FromPicker" Grid.Row="2" Padding="6,4" />
    <TextBlock Grid.Row="3" Margin="0,12,0,4" Foreground="{DynamicResource Brush.TextPrimary}" Text="To" />
    <DatePicker x:Name="ToPicker" Grid.Row="4" Padding="6,4" />
    <StackPanel Grid.Row="5"
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button MinWidth="88"
              Padding="12,6"
              Content="OK"
              IsDefault="True"
              Click="Ok_Click" />
      <Button MinWidth="88"
              Margin="10,0,0,0"
              Padding="12,6"
              Content="Cancel"
              IsCancel="True" />
    </StackPanel>
  </Grid>
  </DockPanel>
</Window>
