<Window x:Class="Accounting.Desktop.Views.PartyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="Customer"
        Width="520"
        Height="640"
        MinHeight="400"
        MinWidth="480"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        Background="{DynamicResource Brush.SurfacePage}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
  <DockPanel LastChildFill="True">
    <ct:BrandedFormHeader DockPanel.Dock="Top"
                          Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                          Subtitle="Customer or supplier master data"
                          IconGlyph="&#xE716;" />
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
    <Grid Margin="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <StackPanel Grid.Row="0">
        <TextBlock Margin="0,0,0,4" Text="Code" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="CodeBox" Margin="0,0,0,10" />
        <TextBlock Margin="0,0,0,4" Text="Name" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="NameBox" Margin="0,0,0,10" />
        <TextBlock x:Name="LedgerLabel" Margin="0,0,0,4" Foreground="{DynamicResource Brush.TextSecondary}" />
        <ComboBox x:Name="LedgerCombo" Margin="0,0,0,10" DisplayMemberPath="Display" />
        <TextBlock Margin="0,0,0,4" Text="Contact" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="ContactBox" Margin="0,0,0,10" />
        <TextBlock Margin="0,0,0,4" Text="Phone / Email" Foreground="{DynamicResource Brush.TextSecondary}" />
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="PhoneBox" Grid.Column="0" />
          <TextBox x:Name="EmailBox" Grid.Column="2" />
        </Grid>
        <TextBlock Margin="0,0,0,4" Text="Physical address" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="Phys1Box" Margin="0,0,0,4" />
        <TextBox x:Name="Phys2Box" Margin="0,0,0,4" />
        <TextBox x:Name="Phys3Box" Margin="0,0,0,4" />
        <TextBox x:Name="PhysCityBox" Margin="0,0,0,10" />
        <TextBlock Margin="0,0,0,4" Text="Postal address" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="Post1Box" Margin="0,0,0,4" />
        <TextBox x:Name="Post2Box" Margin="0,0,0,4" />
        <TextBox x:Name="Post3Box" Margin="0,0,0,4" />
        <TextBox x:Name="PostCodeBox" Margin="0,0,0,10" />
        <TextBlock Margin="0,0,0,4" Text="Tax / registration" Foreground="{DynamicResource Brush.TextSecondary}" />
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="TaxBox" Grid.Column="0" />
          <TextBox x:Name="RegBox" Grid.Column="2" />
        </Grid>
        <TextBlock Margin="0,0,0,4" Text="Credit limit (optional)" Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBox x:Name="CreditLimitBox" Margin="0,0,0,10" />
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Margin="0,0,16,0" Text="Currency" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" />
          <TextBox x:Name="CurrencyBox" Grid.Column="1" MaxLength="3" Width="80" HorizontalAlignment="Left" />
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <CheckBox x:Name="ActiveBox" Content="Active" IsChecked="True" VerticalAlignment="Center" Margin="0,0,24,0" />
          <CheckBox x:Name="OnHoldBox" Content="On hold" VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
      <StackPanel Grid.Row="1"
                  HorizontalAlignment="Right"
                  Margin="0,8,0,0"
                  Orientation="Horizontal">
        <Button MinWidth="88" Padding="10,6" Content="Cancel" IsCancel="True" Click="Cancel_Click" />
        <Button MinWidth="88"
                Margin="8,0,0,0"
                Padding="10,6"
                Content="Save"
                IsDefault="True"
                Click="Save_Click" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
  </DockPanel>
</Window>
