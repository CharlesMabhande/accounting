<UserControl x:Class="Accounting.Desktop.Views.BeltsImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Import from belts database" />
      <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"
                 Text="Pulls StkItem, Client, and Vendor rows from the SQL Server database configured on the API (Belts:SourceConnectionString). Default is .\SQLEXPRESS / belts. Maps legacy master fields into this system only—no third-party binaries or schemas are copied." />
    </StackPanel>
    <StackPanel Grid.Row="1" Margin="0,16,0,8">
      <CheckBox x:Name="ChkStock" Content="Stock items (StkItem)" IsChecked="True" Margin="0,0,0,8" />
      <CheckBox x:Name="ChkCustomers" Content="Customers (Client)" IsChecked="True" Margin="0,0,0,8" />
      <CheckBox x:Name="ChkSuppliers" Content="Suppliers (Vendor)" IsChecked="True" Margin="0,0,0,8" />
      <CheckBox x:Name="ChkOverwrite" Content="Overwrite existing rows with the same code" Margin="0,0,0,12" />
      <StackPanel Orientation="Horizontal">
        <Button HorizontalAlignment="Left"
                Padding="14,8"
                Content="Run import"
                Click="Import_Click" />
        <Button Margin="10,0,0,0"
                Padding="14,8"
                Content="Save log as text…"
                Click="SaveLog_Click" />
      </StackPanel>
      <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" />
    </StackPanel>
    <TextBox x:Name="LogBox"
             Grid.Row="2"
             Margin="0,8,0,0"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             TextWrapping="Wrap"
             FontFamily="Consolas"
             FontSize="12"
             Background="{DynamicResource Brush.SurfaceMuted}" />
  </Grid>
</UserControl>
