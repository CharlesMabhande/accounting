<UserControl x:Class="Accounting.Desktop.Views.CurrenciesExchangeRatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Text="Currencies &amp; exchange rates" />
      <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"
                 Text="Currencies are global. Exchange rates apply to the selected company. Include ZWG (Zimbabwe Gold) when needed." />
    </StackPanel>
    <TabControl Grid.Row="1" Margin="0,12,0,0">
      <TabItem Header="Currencies">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DataGrid x:Name="CurrencyGrid"
                    Grid.Row="0"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    RowHeaderWidth="0"
                    AlternatingRowBackground="{DynamicResource Brush.SurfaceMuted}"
                    CanUserAddRows="False"
                    SelectionChanged="CurrencyGrid_OnSelectionChanged">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80" />
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="Decimals" Binding="{Binding DecimalPlaces}" Width="80" />
            </DataGrid.Columns>
          </DataGrid>
          <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" Background="{DynamicResource Brush.SurfaceMuted}" CornerRadius="4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="56" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Code" Foreground="{DynamicResource Brush.TextSecondary}" />
              <TextBox x:Name="CurCodeBox" Grid.Row="0" Grid.Column="1" Margin="8,0,16,8" Padding="6" MaxLength="8" />
              <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Name" Foreground="{DynamicResource Brush.TextSecondary}" />
              <TextBox x:Name="CurNameBox" Grid.Row="0" Grid.Column="3" Margin="8,0,16,8" Padding="6" />
              <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="Decimals" Foreground="{DynamicResource Brush.TextSecondary}" />
              <TextBox x:Name="CurDecBox" Grid.Row="0" Grid.Column="5" Margin="8,0,0,8" Padding="6" />
              <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Padding="12,6" Content="Refresh" Click="RefreshCurrencies_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="New" Click="NewCurrency_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Style="{DynamicResource AccentPrimaryButton}" Content="Save" Click="SaveCurrency_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Delete" Click="DeleteCurrency_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Export CSV…" Click="ExportCurrenciesCsv_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Export PDF…" Click="ExportCurrenciesPdf_Click" />
                <TextBlock x:Name="CurStatus" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Exchange rates">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DataGrid x:Name="FxGrid"
                    Grid.Row="0"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    RowHeaderWidth="0"
                    AlternatingRowBackground="{DynamicResource Brush.SurfaceMuted}"
                    CanUserAddRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="From" Binding="{Binding FromCurrencyCode}" Width="70" />
              <DataGridTextColumn Header="To" Binding="{Binding ToCurrencyCode}" Width="70" />
              <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat=N6}" Width="100" />
              <DataGridTextColumn Header="Effective" Binding="{Binding EffectiveDate}" Width="100" />
            </DataGrid.Columns>
          </DataGrid>
          <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" Background="{DynamicResource Brush.SurfaceMuted}" CornerRadius="4">
            <StackPanel>
              <UniformGrid Columns="4" Margin="0,0,0,8">
                <StackPanel Margin="0,0,8,0">
                  <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="From code" />
                  <TextBox x:Name="FxFromBox" Padding="6" />
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                  <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="To code" />
                  <TextBox x:Name="FxToBox" Padding="6" />
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                  <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="Rate" />
                  <TextBox x:Name="FxRateBox" Padding="6" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Foreground="{DynamicResource Brush.TextSecondary}" Text="Effective (yyyy-MM-dd)" />
                  <TextBox x:Name="FxDateBox" Padding="6" />
                </StackPanel>
              </UniformGrid>
              <StackPanel Orientation="Horizontal">
                <Button Padding="12,6" Content="Refresh" Click="RefreshFx_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Style="{DynamicResource AccentPrimaryButton}" Content="Save rate" Click="SaveFx_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Delete selected" Click="DeleteFx_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Export CSV…" Click="ExportFxCsv_Click" />
                <Button Margin="8,0,0,0" Padding="12,6" Content="Export PDF…" Click="ExportFxPdf_Click" />
                <TextBlock x:Name="FxStatus" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
