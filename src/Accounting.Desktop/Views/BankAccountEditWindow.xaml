<Window x:Class="Accounting.Desktop.Views.BankAccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ct="clr-namespace:Accounting.Desktop.Controls"
        Title="Bank account"
        Width="440"
        Height="380"
        Icon="pack://application:,,,/Assets/CharlzTechLogo.png"
        Background="{DynamicResource Brush.SurfacePage}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <DockPanel LastChildFill="True">
    <ct:BrandedFormHeader DockPanel.Dock="Top"
                          Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                          Subtitle="Cashbook account"
                          IconGlyph="&#xE8C7;" />
    <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Margin="0,0,0,4" Text="Code" Foreground="{DynamicResource Brush.TextSecondary}" />
    <TextBox x:Name="CodeBox" Grid.Row="1" Margin="0,0,0,12" />

    <TextBlock Grid.Row="2" Margin="0,0,0,4" Text="Name" Foreground="{DynamicResource Brush.TextSecondary}" />
    <TextBox x:Name="NameBox" Grid.Row="3" Margin="0,0,0,12" />

    <TextBlock Grid.Row="4" Margin="0,0,0,4" Text="Ledger account" Foreground="{DynamicResource Brush.TextSecondary}" />
    <ComboBox x:Name="LedgerCombo" Grid.Row="5" Margin="0,0,0,12" DisplayMemberPath="Display" />

    <TextBlock Grid.Row="6" Margin="0,0,0,4" Text="Currency" Foreground="{DynamicResource Brush.TextSecondary}" />
    <TextBox x:Name="CurrencyBox" Grid.Row="7" Margin="0,0,0,12" MaxLength="3" />

    <StackPanel Grid.Row="8" Orientation="Horizontal">
      <CheckBox x:Name="ActiveBox" Content="Active" IsChecked="True" VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Row="9"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Orientation="Horizontal">
      <Button MinWidth="88" Padding="10,6" Content="Cancel" IsCancel="True" Click="Cancel_Click" />
      <Button MinWidth="88"
              Margin="8,0,0,0"
              Padding="10,6"
              Content="Save"
              IsDefault="True"
              Click="Save_Click" />
    </StackPanel>
  </Grid>
  </DockPanel>
</Window>
