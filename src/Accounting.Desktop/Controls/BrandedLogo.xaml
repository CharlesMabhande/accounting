<UserControl x:Class="Accounting.Desktop.Controls.BrandedLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">
  <!-- No solid white plate: logo blends on blue bars; soft glow reads on dark backgrounds -->
  <Border x:Name="ClipBorder"
          Background="Transparent"
          BorderThickness="0"
          ClipToBounds="True"
          SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="14"
                        ShadowDepth="0"
                        Opacity="0.55"
                        Color="White" />
    </Border.Effect>
    <Image x:Name="LogoImage"
           RenderOptions.BitmapScalingMode="HighQuality"
           Stretch="Uniform"
           Source="pack://application:,,,/Assets/CharlzTechLogo.png" />
  </Border>
</UserControl>
