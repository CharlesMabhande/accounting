{
  "Backup": {
    "RootPath": ""
  },
  "Api": {
    "EnableSwagger": false
  },
  "Database": {
    "Provider": "SqlServer",
    "SqlitePath": "Data/Accounting.db",
    "AutoProvision": false,
    "AutoInstallSsms": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AccountingDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Belts": {
    "SourceConnectionString": "Server=.\\SQLEXPRESS;Database=belts;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
